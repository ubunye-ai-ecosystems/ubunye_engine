# Environment variables consumed by the ABSA telematics ETL pipeline.
#
# In CI these are stored as GitHub environment secrets (nonprod / prod)
# and passed to ``databricks bundle deploy`` via ``--var="telm_catalog=..."``.
# Locally they feed the Jinja context in ``config.yaml`` directly.
#
# Confidentiality: do NOT commit concrete catalog/schema values. This file
# is a template only.

# Unity Catalog identifiers for the telematics data. Per-environment.
TELM_CATALOG=<unity-catalog-name>
TELM_SCHEMA=<unity-schema-name>

# Databricks auth (service principal + OAuth is required for paid workspaces).
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_CLIENT_ID=<service-principal-application-id>
DATABRICKS_CLIENT_SECRET=<oauth-secret>
